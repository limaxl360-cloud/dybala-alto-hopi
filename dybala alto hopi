-- SCAN BASES
local function ScanBases()

    local highest = 0
    local richestPlayer = nil
    local totalValue = 0

    for _,p in pairs(Players:GetPlayers()) do

        local stats = p:FindFirstChild("leaderstats")

        if stats then
            for _,v in pairs(stats:GetChildren()) do

                if tonumber(v.Value) then

                    totalValue += v.Value

                    if v.Value > highest then
                        highest = v.Value
                        richestPlayer = p.Name
                    end

                end

            end
        end

    end

    if richestPlayer then
        richest.Text = "Richest: "..richestPlayer
    end

    total.Text = "Total Value: "..totalValue

end

-- DETECTAR BRAINROT
local function DetectBrainrot()

    for _,v in pairs(workspace:GetDescendants()) do

        if v:IsA("NumberValue") or v:IsA("IntValue") then

            if v.Value >= VALOR300 then
                status.Text="300M Brainrot"
                Notify("300M Brainrot encontrado")
                CopyJob()
                return true
            end

            if v.Value >= VALOR50 then
                status.Text="50M Brainrot"
                Notify("50M Brainrot encontrado")
                CopyJob()
                return true
            end

        end

        if string.find(string.lower(v.Name),"secret") then
            status.Text="Secret Brainrot"
            Notify("Secret Brainrot encontrado")
            CopyJob()
            return true
        end

    end

    return false

end

-- ULTRA FAST SERVER HOP
local function ServerHop()

    local cursor = ""

    while true do

        local url = "https://games.roblox.com/v1/games/"..PlaceID.."/servers/Public?sortOrder=Asc&limit=100&cursor="..cursor

        local success,res = pcall(function()
            return game:HttpGet(url)
        end)

        if success then

            local data = HttpService:JSONDecode(res)

            for _,server in pairs(data.data) do

                if server.playing < server.maxPlayers then

                    if not visited[server.id] then

                        visited[server.id] = true

                        status.Text = "Teleportando..."

                        TeleportService:TeleportToPlaceInstance(
                            PlaceID,
                            server.id,
                            player
                        )

                        task.wait(0.15)

                    end
                end
            end

            cursor = data.nextPageCursor or ""

        end

        task.wait(0.15)

    end

end

